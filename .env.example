# =========================================================
# GhostCorp — an autonomous AI software company
# Copy this file to `.env` and fill in your real keys.
# NEVER commit your real .env file.
# =========================================================

# --- NVIDIA NIM ---
# Get a key at https://build.nvidia.com (format: nvapi-...)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# Optional override of the NVIDIA NIM base URL (OpenAI-compatible endpoint)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model IDs (defaults shown — override only if needed)
CEO_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
FAST_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# --- LangSmith (Observability) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=ghostcorp-hackathon

# --- GhostCorp app (the AI software company) ---
GHOSTCORP_ENV=development

# Mission-control dashboard
GHOSTCORP_HOST=0.0.0.0
GHOSTCORP_PORT=8000

# Live product preview (the app the AI builds runs as its own process)
GHOSTCORP_PRODUCT_HOST=127.0.0.1
GHOSTCORP_PRODUCT_PORT=8100
# URL the browser uses for the preview iframe (override if not on localhost)
# GHOSTCORP_PREVIEW_URL=http://localhost:8100
# Set to 1 to disable the live preview subprocess (e.g. in CI)
# GHOSTCORP_NO_PREVIEW=0

# Where the AI's product workspace is materialized (its own git repo)
# GHOSTCORP_WORKSPACE=./workspace/product

# --- Legacy SimCorp business-simulation mode (optional) ---
DATABASE_URL=sqlite:///./db/ghostcorp.db
