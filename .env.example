# =========================================================
# SimCorp — AI-Operated SaaS Startup Simulation
# Copy this file to `.env` and fill in your real keys.
# NEVER commit your real .env file.
# =========================================================

# --- NVIDIA NIM ---
# Get a key at https://build.nvidia.com (format: nvapi-...)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# Optional override of the NVIDIA NIM base URL (OpenAI-compatible endpoint)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model IDs (defaults shown — override only if needed)
CEO_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
FAST_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# --- LangSmith (Observability) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=simcorp-hackathon

# --- App ---
SIMCORP_ENV=development
DATABASE_URL=sqlite:///./db/simcorp.db
